      .about-card-stack { position: relative; width: 100%; max-width: 320px; height: 560px; }
      .a-card { position: absolute; padding: 1.25rem 1.5rem; width: 100%; text-align: left; font-weight: 700; transform: rotate(var(--rot)); top: var(--top); left: var(--left); transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); display: flex; align-items: center; gap: 0.75rem; cursor: default; }
      .a-card .icon { font-size: 1.4rem; }
      .a-card:nth-child(1) { --rot: -4deg; --top: 0px; --left: 0; z-index: 7; }
      .a-card:nth-child(2) { --rot: 2deg; --top: 80px; --left: 20px; z-index: 6; opacity: 0.95; }
      .a-card:nth-child(3) { --rot: -2deg; --top: 160px; --left: -15px; z-index: 5; opacity: 0.9; }
      .a-card:nth-child(4) { --rot: 5deg; --top: 240px; --left: 10px; z-index: 4; opacity: 0.85; }
      .a-card:nth-child(5) { --rot: -3deg; --top: 320px; --left: -5px; z-index: 3; opacity: 0.8; }
      .a-card:nth-child(6) { --rot: 4deg; --top: 400px; --left: 15px; z-index: 2; opacity: 0.75; }
      .a-card:nth-child(7) { --rot: -1deg; --top: 480px; --left: -10px; z-index: 1; opacity: 0.7; }
      .a-card:hover { transform: scale(1.1) translateY(-10px) rotate(0); z-index: 10; opacity: 1; border-color: var(--accent-primary); box-shadow: 0 15px 45px rgba(59, 130, 246, 0.3); }

      /* ─── RESPONSIVE ─── */
      @media(max-width:1024px){
        .about-grid { grid-template-columns: 1fr; text-align: center; gap: 4rem; }
        .about-countries { justify-content: center; }
        .about-visual { height: 350px; margin-top: 2rem; }
        .about-card-stack { margin: 0 auto; }
        .hero-inner{grid-template-columns:1fr;text-align:center}
        .hero h1{max-width:100%;margin-left:auto;margin-right:auto}
        .title-part{display:inline; white-space: normal; margin-right: 0.5rem;}
        @media(max-width:768px) { .title-part{display:block; margin-right:0;} }
        .hero-description-area{flex-direction:column;gap:2rem;align-items:center;text-align:center}
        .hero-subtitle{margin-left:auto;margin-right:auto}
        .hero-cta{justify-content:center}
        .hero-proof{flex-direction:row;justify-content:center;width:100%;max-width:600px}
        .hero-visual{max-width:500px;margin:2rem auto 0}
        .pricing-grid{grid-template-columns:1fr}
        .method-grid, .method-steps{grid-template-columns:repeat(2,1fr)}
        .audit-grid{grid-template-columns:1fr}
      }
      @media(max-width:768px){
        .nav-links{display:none}
        .hero{padding:5rem 0 3rem;min-height:auto}
        .hero h1{font-size:2rem}
        .method-grid, .method-steps, .form-grid{grid-template-columns:1fr}
        .footer-inner{flex-direction:column;gap:2rem;text-align:center}
      }
    </style>
	</body>
