      .mockup-img { width: 100%; display: block; border-radius: var(--radius-md); filter: brightness(0.9) contrast(1.1); transition: filter 0.3s; }
      .audit-mockup:hover .mockup-img { filter: brightness(1); }
      .mockup-overlay { position: absolute; bottom: 1.5rem; right: 1.5rem; }
      .mockup-tag { background: rgba(0,0,0,0.7); backdrop-filter: blur(5px); padding: 0.5rem 1rem; border-radius: var(--radius-pill); font-size: 0.75rem; color: #fff; font-weight: 600; letter-spacing: 0.5px; border: 1px solid rgba(255,255,255,0.1); }

      /* ─── CONTACT FORM ─── */
      .cta-box{padding:5rem 3rem;background:linear-gradient(135deg,rgba(59,130,246,0.08),rgba(139,92,246,0.08));border-color:rgba(59,130,246,0.15);border-radius:var(--radius-lg)}
