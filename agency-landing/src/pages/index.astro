      .pricing-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;align-items:stretch}
      .pricing-card{padding:2rem 1.5rem;display:grid;grid-template-rows: auto auto 1fr auto;position:relative;transition:border-color var(--transition-base),transform var(--transition-base)}
      .pricing-card:hover{border-color:var(--glass-border-hover);transform:translateY(-4px)}
      .pricing-card.featured{border-color:rgba(59,130,246,0.3);box-shadow:0 0 60px rgba(59,130,246,0.08)}
      .card-badge-top{position:absolute;top:-14px;left:50%;transform:translateX(-50%);background:linear-gradient(135deg,var(--accent-primary),var(--accent-secondary));padding:0.3rem 1.2rem;border-radius:var(--radius-pill);font-size:0.7rem;font-weight:700;letter-spacing:1px;color:#fff;white-space:nowrap}
      .card-top{margin-bottom:1.5rem}
      .plan-icon{font-size:2rem;margin-bottom:0.75rem}
      .card-top h3{font-size:1.35rem;margin-bottom:0.25rem}
      .plan-desc{color:var(--text-muted);font-size:0.88rem}
      .card-price{margin-bottom:1.5rem;padding-bottom:1.5rem;border-bottom:1px solid var(--glass-border)}
      .card-body{display:flex;flex-direction:column;gap:1rem;margin-bottom:2rem}
      .card-footer{display:flex;flex-direction:column;gap:0.5rem}
      .card-price .from{font-size:0.8rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.05em}
      .price-row{display:flex;align-items:baseline;gap:0.15rem;margin:0.25rem 0}
      .currency{font-size:1.4rem;font-weight:700}
      .amount{font-size:2.5rem;font-weight:900;line-height:1}
      .unit{font-size:0.85rem;color:var(--text-muted);margin-left:0.5rem;font-weight:500}
      .price-note{font-size:0.78rem;color:var(--text-dim)}
      .features-list{padding:0;margin-bottom:1.5rem;flex-grow:1}
      .features-list li{margin-bottom:0.8rem;font-size:0.9rem;color:var(--text-muted)}
      .positive{color:var(--accent-emerald) !important;font-weight:500}
      .card-compare{background:rgba(255,255,255,0.03);border:1px solid var(--glass-border);border-radius:var(--radius-sm);padding:0.6rem 0.8rem;margin-bottom:0.5rem;display:flex;flex-direction:column;gap:0.1rem}
      .card-compare.inhouse{background:rgba(244,63,94,0.04);border-color:rgba(244,63,94,0.1);margin-bottom:1.5rem}
      .compare-label{font-size:0.7rem;color:var(--text-dim);text-transform:uppercase;letter-spacing:0.03em}
