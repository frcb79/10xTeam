      /* ─── AUDIT SECTION ─── */
      .section-audit { background: linear-gradient(180deg, rgba(59,130,246,0.02) 0%, transparent 100%); }
      .audit-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
      .audit-content p { color: var(--text-muted); line-height: 1.8; margin-bottom: 1.5rem; font-size: 1.05rem; }
